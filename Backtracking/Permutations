class Solution {
    public void helper(List<List<Integer>> ans,List<Integer> combinations,boolean visited[],int nums[]){
        
            if(combinations.size()==nums.length){
                ans.add(new ArrayList<>(combinations));
                return;
            }
        for(int i = 0;i<nums.length;i++){
            if(!visited[i]){
                visited[i] = true;
                combinations.add(nums[i]);
                helper(ans, combinations,visited,nums);
                combinations.remove(combinations.size()-1);
                visited[i] = false;
            }
        }
    }

    public List<List<Integer>> permute(int[] nums) {
        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> combinations = new ArrayList<>();

        boolean visited[] = new boolean[nums.length];
        helper(ans,combinations, visited,nums);
        return ans;
        
    }
}
