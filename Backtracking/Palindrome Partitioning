class Solution {

    public boolean isPalidrome(String s, int start, int end){
        while(start < end){
            if(s.charAt(start)!=s.charAt(end)){
                return false;
            }
            start++;
            end--;
        }
        return true;
    }
    public void helper(String s , List<List<String>> ans, List<String> sublist ,int index){
        if(index == s.length()){
            ans.add(new ArrayList<>(sublist));
        }

        for(int i = index ;i<s.length();i++){  //index: start ,i = end
            if(isPalidrome(s,  index, i)){

                sublist.add(s.substring(index, i+1));
                helper(s, ans, sublist, i+1);
                sublist.remove(sublist.size()-1);
                
            }
        }

    }

    public List<List<String>> partition(String s) {
        List<List<String>> ans = new ArrayList<>();
        List<String> sublist = new ArrayList<>();
        int index  = 0;
        helper(s,ans,sublist,index);
        return ans;
    }

}
