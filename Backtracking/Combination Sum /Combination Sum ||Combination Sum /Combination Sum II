class Solution {

    public void helper(int candidates[], int target,List<List<Integer>> ans,List<Integer> combinations,int index ){
        if(target==0){
            ans.add(new ArrayList<>(combinations));
            return;
        }

        for(int i = index;i<candidates.length;i++){
            if(i>index && candidates[i]==candidates[i-1]) continue;
            if(candidates[i] > target) break;
            
            combinations.add(candidates[i]);
            helper(candidates, target-candidates[i],ans,combinations,i+1);
            combinations.remove(combinations.size()-1);
        }
    
    }
    public List<List<Integer>> combinationSum2(int[] candidates, int target) {
        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> combinations = new ArrayList<>(); 
        Arrays.sort(candidates);
        int index = 0;
        helper(candidates, target, ans, combinations, index);
        return ans;
    }
}
