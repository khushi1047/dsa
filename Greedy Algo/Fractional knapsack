class Pair{
    int objects;
    double valueByWeight;
    Pair(int objects, double valueByWeight){
        this.objects = objects;
        this.valueByWeight =valueByWeight;
    }
}
class Solution {
    public double fractionalKnapsack(int[] val, int[] wt, int capacity) {
       
        List<Pair> list = new ArrayList<>();
        for(int i = 0;i<val.length;i++){
            double ratio = (double)val[i]/wt[i];
            list.add(new Pair(i, ratio));
        }
        
        list.sort((a,b)->  Double.compare(b.valueByWeight , a.valueByWeight));
        
        double ans = 0.0;
      
        for(int i =0;i<list.size();i++){
            int index = list.get(i).objects;
            if( wt[index] <= capacity){
                ans = ans + val[index];
                capacity =  capacity- wt[index];
            }
            else{
                ans = ans + list.get(i).valueByWeight * capacity;
                break;
            }
            
        }
        return ans;
        
    }
}
