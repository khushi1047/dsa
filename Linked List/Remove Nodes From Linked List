       ListNode curr = head, prev = null, next = null;
        while (curr != null) {
            next = curr.next;
            curr.next = prev;
            prev = curr;
            curr = next;
        }

        // Step 2: Filter nodes (keep nodes >= max so far)
        int max = Integer.MIN_VALUE;
        ListNode dummy = new ListNode(0);
        ListNode temp = dummy;
        head = prev; // head now points to reversed list

        while (head != null) {
            if (head.val >= max) {
                max = head.val;
                temp.next = head;
                temp = head; // move `temp` when keeping node
            }
            head = head.next; // advance traversal
        }
        temp.next = null; // cut dangling links

        // Step 3: Reverse again to restore order
        curr = dummy.next;
        prev = null;
        while (curr != null) {
            next = curr.next;
            curr.next = prev;
            prev = curr;
            curr = next;
        }

        return prev; 

    }
