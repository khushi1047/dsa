    //   optimal:
    int open = 0,close = 0;
    for(int i = 0;i<s.length();i++){
        if(s.charAt(i)=='('){
            open++;
        }
        else {
            if(open>0){
                open--;
            }
            else{
                close++;
            }
        }
        
    }
    if(open>0 && close>0){  //  ))((
        return open+close;
    }
    else if(open>0 && close==0){
        return open;
    }
    else{
        return close;
    }
    }
  
