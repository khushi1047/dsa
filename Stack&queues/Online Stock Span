class Pair{
    int val;
    int index;
    Pair(int val, int index){
        this.val = val;
        this.index = index;
    }
}
class StockSpanner {
    Stack<Pair> st;
    int curridx;
    public StockSpanner() {
        st = new Stack<>();
        curridx = -1;
        
    }
    
    public int next(int price) {
        curridx = curridx+1;
        while(!st.isEmpty() && st.peek().val<=price){
            st.pop();
        }
        int ans = curridx - (st.isEmpty() ? -1 : st.peek().index);
        st.push(new Pair(price, curridx));
        return ans;
    }
    
}

