class Solution {
    public int maxProduct(int[] nums) {
        // observations:
        // 1. all are +ve;
        // 2. negatives are even;
        // 3. negatives are odd (ignore one odd rest left with even negatives)
        // 4. what if zeroes in between in that case convert it to 1;

        int pref = 1;
        int suff = 1;
        int maxi = Integer.MIN_VALUE;
        for(int i = 0;i<nums.length;i++){
            if(pref==0) pref = 1;
            if(suff==0) suff = 1;
            pref = pref * nums[i];
            suff = suff * nums[nums.length-i-1];
            maxi = Math.max(maxi, Math.max(pref, suff));
        }
        return maxi;
    }
}
